generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  participant
  judge
  organizer
  admin
}

enum EventStatus {
  draft
  open
  active
  judging
  closed
}

enum MemberRole {
  leader
  member
}

enum RegistrationStatus {
  pending
  confirmed
  cancelled
  waitlisted
}

enum ProjectStatus {
  draft
  submitted
  under_review
  scored
}

enum AnnouncementPriority {
  info
  warning
  urgent
}

enum AnnouncementTarget {
  all
  participants
  judges
  organizers
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  username     String    @unique
  avatarUrl    String?   @map("avatar_url")
  bio          String?
  githubUrl    String?   @map("github_url")
  linkedinUrl  String?   @map("linkedin_url")
  role         UserRole
  isVerified   Boolean   @default(false) @map("is_verified")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  // Relationships
  organizedEvents     Event[]            @relation("EventOrganizer")
  ledTeams            Team[]             @relation("TeamLeader")
  teamMemberships     TeamMember[]
  registrations       Registration[]
  judgeAssignments    EventJudge[]       @relation("JudgeAssignments")
  assignedJudgeEvents EventJudge[]       @relation("AssignedByOrganizer")
  scores              Score[]
  announcements       Announcement[]     @relation("AnnouncementAuthor")
  announcementReads   AnnouncementRead[]

  @@map("users")
}

model Event {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug               String      @unique
  title              String
  description        String
  bannerUrl          String?     @map("banner_url")
  organizerId        String      @map("organizer_id") @db.Uuid
  status             EventStatus @default(draft)
  maxTeamSize        Int         @default(4) @map("max_team_size")
  minTeamSize        Int         @default(1) @map("min_team_size")
  maxRegistrations   Int?        @map("max_registrations")
  registrationOpen   DateTime    @map("registration_open")
  registrationClose  DateTime    @map("registration_close")
  eventStart         DateTime    @map("event_start")
  eventEnd           DateTime    @map("event_end")
  submissionDeadline DateTime    @map("submission_deadline")
  timezone           String
  prizePool          Json        @map("prize_pool")
  tags               String[]
  isPublic           Boolean     @default(true) @map("is_public")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  // Relationships
  organizer     User           @relation("EventOrganizer", fields: [organizerId], references: [id])
  teams         Team[]
  registrations Registration[]
  projects      Project[]
  judges        EventJudge[]
  announcements Announcement[]

  @@index([status])
  @@index([organizerId])
  @@map("events")
}

model Team {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  leaderId   String   @map("leader_id") @db.Uuid
  name       String
  inviteCode String   @unique @map("invite_code")
  track      String?
  isOpen     Boolean  @default(true) @map("is_open")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relationships
  event         Event          @relation(fields: [eventId], references: [id])
  leader        User           @relation("TeamLeader", fields: [leaderId], references: [id])
  members       TeamMember[]
  registrations Registration[]
  project       Project?

  @@unique([eventId, name])
  @@index([eventId])
  @@index([leaderId])
  @@map("teams")
}

model TeamMember {
  teamId   String     @map("team_id") @db.Uuid
  userId   String     @map("user_id") @db.Uuid
  role     MemberRole
  joinedAt DateTime   @default(now()) @map("joined_at")

  // Relationships
  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([teamId, userId])
  @@map("team_members")
}

model Registration {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String             @map("event_id") @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  teamId           String?            @map("team_id") @db.Uuid
  status           RegistrationStatus @default(pending)
  registrationData Json               @map("registration_data")
  registeredAt     DateTime           @default(now()) @map("registered_at")
  confirmedAt      DateTime?          @map("confirmed_at")
  cancelledAt      DateTime?          @map("cancelled_at")

  // Relationships
  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  team  Team? @relation(fields: [teamId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("registrations")
}

model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String        @map("event_id") @db.Uuid
  teamId      String        @unique @map("team_id") @db.Uuid
  title       String
  description String
  techStack   String[]      @map("tech_stack")
  demoUrl     String?       @map("demo_url")
  repoUrl     String?       @map("repo_url")
  deckUrl     String?       @map("deck_url")
  videoUrl    String?       @map("video_url")
  status      ProjectStatus @default(draft)
  submittedAt DateTime?     @map("submitted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relationships
  event  Event   @relation(fields: [eventId], references: [id])
  team   Team    @relation(fields: [teamId], references: [id])
  scores Score[]

  @@unique([eventId, teamId])
  @@index([eventId])
  @@index([teamId])
  @@map("projects")
}

model EventJudge {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  judgeId    String   @map("judge_id") @db.Uuid
  track      String?
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by") @db.Uuid

  // Relationships
  event          Event @relation(fields: [eventId], references: [id])
  judge          User  @relation("JudgeAssignments", fields: [judgeId], references: [id])
  assignedByUser User  @relation("AssignedByOrganizer", fields: [assignedBy], references: [id])

  @@unique([eventId, judgeId])
  @@index([eventId])
  @@index([judgeId])
  @@map("event_judges")
}

model Score {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  judgeId      String   @map("judge_id") @db.Uuid
  innovation   Int
  technical    Int
  impact       Int
  presentation Int
  comments     String?
  submittedAt  DateTime @default(now()) @map("submitted_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  project Project @relation(fields: [projectId], references: [id])
  judge   User    @relation(fields: [judgeId], references: [id])

  @@unique([projectId, judgeId])
  @@index([projectId])
  @@index([judgeId])
  @@map("scores")
}

model Announcement {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String               @map("event_id") @db.Uuid
  authorId    String               @map("author_id") @db.Uuid
  title       String
  body        String
  priority    AnnouncementPriority @default(info)
  target      AnnouncementTarget   @default(all)
  isPublished Boolean              @default(false) @map("is_published")
  publishedAt DateTime?            @map("published_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  // Relationships
  event  Event              @relation(fields: [eventId], references: [id])
  author User               @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  reads  AnnouncementRead[]

  @@index([eventId])
  @@map("announcements")
}

model AnnouncementRead {
  announcementId String   @map("announcement_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  readAt         DateTime @default(now()) @map("read_at")

  // Relationships
  announcement Announcement @relation(fields: [announcementId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([announcementId, userId])
  @@index([announcementId])
  @@map("announcement_reads")
}
